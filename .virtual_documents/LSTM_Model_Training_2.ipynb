import numpy as np
import os

from pydub import AudioSegment, effects
import librosa
import noisereduce as nr

import tensorflow as tf
import keras
import sklearn


X = np.load('Data/Features.npy')
Y = np.load('Data/Labels.npy')


# Split to train, validation, and test sets.
from sklearn.model_selection import train_test_split

x_train, x_tosplit, y_train, y_tosplit = train_test_split(X,
                                                          Y,
                                                          test_size=0.125,
                                                          random_state=1)
x_val, x_test, y_val, y_test = train_test_split(x_tosplit,
                                                y_tosplit,
                                                test_size=0.304,
                                                random_state=1)

#'One-hot' vectors for Y: emotion classification
y_train_class = tf.keras.utils.to_categorical(y_train, 8, dtype='int8')
y_test_class = tf.keras.utils.to_categorical(y_test, 8, dtype='int8')
y_val_class = tf.keras.utils.to_categorical(y_val, 8, dtype='int8')


# x_train, x_val, and x_test shape check.
print(np.shape(x_train))
print(np.shape(x_val))
print(np.shape(x_test))


print(np.shape(y_train_class))
print(np.shape(y_val_class))
print(np.shape(y_test_class))


from keras.models import Sequential
from keras import layers
from keras import optimizers
from keras import callbacks
from keras.layers import Dropout


# Initializing the model

model = Sequential()
model.add(layers.LSTM(128, return_sequences=True, input_shape=(X.shape[1:3])))
model.add(layers.LSTM(128))
model.add(layers.Dense(64, activation='relu'))
model.add(layers.Dense(32, activation='relu'))
model.add(layers.Dense(8, activation='softmax'))
print(model.summary())

batch_size = 64

# Callbacks functions
checkpoint_path = 'Models/best_weights.hdf5'

#-> Save the best weights
mcp_save = callbacks.ModelCheckpoint(checkpoint_path,
                                     save_best_only=True,
                                     monitor='val_categorical_accuracy',
                                     mode='max')
#-> Reduce learning rate after 100 epoches without improvement.
rlrop = callbacks.ReduceLROnPlateau(monitor='val_categorical_accuracy',
                                    factor=0.01,
                                    patience=200)


tf.config.list_physical_devices()


# Compile & train
with tf.device('/device:GPU:0'):
    model.compile(loss='categorical_crossentropy',
                  optimizer='RMSProp',
                  metrics=['categorical_accuracy'])

    history = model.fit(x_train,
                        y_train_class,
                        epochs=400,
                        batch_size=batch_size,
                        validation_data=(x_val, y_val_class),
                        callbacks=[mcp_save, rlrop])
    # Define the best weights to the model.
    model.load_weights(checkpoint_path)


from keras.models import load_model

model = load_model('/content/drive/MyDrive/Colab Notebooks/best_weights.hdf5')


from sklearn.metrics import confusion_matrix
import seaborn as sns
import matplotlib.pyplot as plt


loss, acc = model.evaluate(x_val, y_val_class, verbose=2)


loss, acc = model.evaluate(x_test, y_test_class, verbose=2)


# Loss, Accuracy presentation

# Plot history: Loss
plt.plot(history.history['loss'], label='Loss (training data)')
plt.plot(history.history['val_loss'], label='Loss (validation data)')
plt.title('Loss for train and validation')
plt.ylabel('Loss value')
plt.xlabel('No. epoch')
plt.legend(loc="upper left")
plt.show()

#Plot history: Accuracy
plt.plot(history.history['categorical_accuracy'], label='Acc (training data)')
plt.plot(history.history['val_categorical_accuracy'],
         label='Acc (validation data)')
plt.title('Model accuracy')
plt.ylabel('Acc %')
plt.xlabel('No. epoch')
plt.legend(loc="upper left")
plt.show()



